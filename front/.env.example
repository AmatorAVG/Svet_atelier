# YouTube Summary - Environment Variables
# Скопируйте этот файл в .env.local и заполните значения

# Supadata.ai API Key
# Получите ключ на https://supadata.ai
SUPADATA_API_KEY=your_supadata_api_key_here

# OpenRouter API Key
# Получите ключ на https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_api_key_here